{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "admin/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/admin/(.*)", "dest": "/admin/$1" },
    { "src": "/(.*\\.html)$", "dest": "/$1" },
    { "src": "/(.*\\.css)$", "dest": "/$1" },
    { "src": "/(.*\\.js)$", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
