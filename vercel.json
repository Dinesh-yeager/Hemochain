{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "**/*.{html,css,js,svg,png,jpg,ico}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/admin$", "dest": "/admin/index.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
